fn math_oprs() -> u8 {
    mut i32 x = 0;
    5+5; x+5; 5+x; x+x;
    5-5; x-5; 5-x; x-x;
    5*5; x*5; 5*x; x*x;
    5/5; x/5; 5/x; x/x;
    5%5; x%5; 5%x; x%x;
    x=5; x=x;

    if(x not_eq 5) return 4;
    if(++x not_eq 6) return 4;
    if(x++ not_eq 6) return 4;
    if(-x not_eq -7) return 4;
    if(--x not_eq 6) return 4;
    if(x-- not_eq 6) return 4;

    return 0;
}

fn condition_oprs() -> u8 {
    bool true_cond = true;
    bool false_cond = false;
    mut i32 x = 0;

    if(false_cond) return 2;
    if(not true_cond) return 2;

    if(true_cond eq false_cond) return 2;
    if(true_cond not_eq true_cond) return 2;
    if(5 eq 6) return 2;
    if(5 not_eq 5) return 2;
    if(x not_eq x) return 2;

    if(5<5) return 2;
    if(5>5) return 2;
    if(5>6 or 5>=6) return 2;
    if(5<4 or 5<=4) return 2;
    if(5>x and 5<x) return 2;
    if(5<=x and 5>=x and (5 not_eq x)) return 2;

    if( not (true_cond and true_cond)) return 2;
    if(not (true_cond or true_cond)) return 2;
    if(true_cond xor true_cond) return 2;

    if(false_cond and false_cond) return 2;
    if(false_cond or false_cond) return 2;
    if(false_cond xor false_cond) return 2;

    return 0;
}

fn bitwise_oprs() -> u8 {
   mut i32 x = 5;
   if( (5 bitand 5) not_eq 5 ) return 1;
   if( (x bitand 5) not_eq (5 bitand x) ) return 1;
   if( (x bitand x) not_eq x ) return 1;

   if( (5 bitor 5) not_eq 5 ) return 1;
   if( (x bitor 5) not_eq (5 bitor x) ) return 1;
   if( (x bitor x) not_eq x ) return 1;

   if( (5 bitxor 5) not_eq 0 ) return 1;
   if( (x bitxor 5) not_eq (5 bitxor x) ) return 1;
   if( (x bitxor x) not_eq 0 ) return 1;

   return 0;
}

fn main() -> i32 {
    return bitwise_oprs() bitor condition_oprs() bitor math_oprs();
}