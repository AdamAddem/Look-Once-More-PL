global mut i32 mutable_global = 2;
global i32 immutable_global = 5;

fn if_statements() {
    mut bool condition = true;
    if(condition) ;
    if(true) {}
    if(false) {}
    if(condition) { condition = false; }
    else if(condition) { condition = true; }
    elif(true) { condition = false; }
    else mut i32 scoped = junk;

    return;
}

fn while_statements() {
    mut bool condition = true;
    while(condition) ;
    while(true) {}
    while(false) {}
    while(condition eq false) {}
    while(condition not_eq true) { mut i32 scoped = junk; }
}


fn math_oprs() -> u8 {
    mut i32 x = 0;
    5+5; x+5; 5+x; x+x;
    5-5; x-5; 5-x; x-x;
    5*5; x*5; 5*x; x*x;
    5/5; x/5; 5/x; x/x;
    5%5; x%5; 5%x; x%x;
    x=5; x=x;

    if(x not_eq 5) return 4;
    if(++x not_eq 6) return 4;
    if(x++ not_eq 6) return 4;
    if(-x not_eq -7) return 4;
    if(--x not_eq 6) return 4;
    if(x-- not_eq 6) return 4;

    return 0;
}

fn condition_oprs() -> u8 {
    bool true_cond = true;
    bool false_cond = false;
    mut i32 x = 0;

    if(false_cond) return 2;
    if(not true_cond) return 2;

    if(true_cond eq false_cond) return 2;
    if(true_cond not_eq true_cond) return 2;
    if(5 eq 6) return 2;
    if(5 not_eq 5) return 2;
    if(x not_eq x) return 2;

    if(5<5) return 2;
    if(5>5) return 2;
    if(5>6 or 5>=6) return 2;
    if(5<4 or 5<=4) return 2;
    if(5>x and 5<x) return 2;
    if(5<=x and 5>=x and (5 not_eq x)) return 2;

    if( not (true_cond and true_cond)) return 2;
    if(not (true_cond or true_cond)) return 2;
    if(true_cond xor true_cond) return 2;

    if(false_cond and false_cond) return 2;
    if(false_cond or false_cond) return 2;
    if(false_cond xor false_cond) return 2;

    return 0;
}

fn bitwise_oprs() -> u8 {
   mut i32 x = 5;
   if( (5 bitand 5) not_eq 5 ) return 1;
   if( (x bitand 5) not_eq (5 bitand x) ) return 1;
   if( (x bitand x) not_eq x ) return 1;

   if( (5 bitor 5) not_eq 5 ) return 1;
   if( (x bitor 5) not_eq (5 bitor x) ) return 1;
   if( (x bitor x) not_eq x ) return 1;

   if( (5 bitxor 5) not_eq 0 ) return 1;
   if( (x bitxor 5) not_eq (5 bitxor x) ) return 1;
   if( (x bitxor x) not_eq 0 ) return 1;

   return 0;
}

fn empty_function() {}
fn return_type_function() -> bool { return true; }

fn return_within_scope() -> bool {
    if(true)
        return true;
    else
        return false;
}

fn zeroes() {
    i8 i8zero = 0; u8 u8zero = 0u;
    i16 i16zero = 0; u16 u16zero = 0u;
    i32 i32zero = 0; u32 u32zero = 0u;
    i64 i64zero = 0; u64 u64zero = 0u;

    f32 f32zero = 0f; f64 f64zero = 0.;
}

fn _8bit() {
    i8 imin = -128; i8 imax = 127;
    u8 umax = 255u;
}

fn _16bit() {
    i16 imin = -32768; i16 imax = 32767;
    u16 umax = 65535u;
}

fn _32bit() {
    i32 imin = -2147483648; i32 imax = 2147483647;
    u32 umax = 4294967295u;
}

fn _64bit() {
    i64 imin = -9223372036854775808; i64 imax = 9223372036854775807;
    u64 umax = 18446744073709551615u;
}

fn main() -> i32 {
    zeroes(); _8bit(); _16bit(); _32bit(); _64bit();
    return 0;
}