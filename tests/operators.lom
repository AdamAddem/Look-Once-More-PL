fn operators() {
    mut i32 x = 0;

    5+5; x+5; 5+x; x+x;
    5-5; x-5; 5-x; x-x;
    5*5; x*5; 5*x; x*x;
    5/5; x/5; 5/x; x/x;
    5^5; x^5; 5^x; x^x;
    5%5; x%5; 5%x; x%x;

    x=5; x=x;
    bool condition =
        (5<5) and (x<5) and (5<x) and (x<x) and
        (5>5) or (x>5) or (5>x) or (x>x) xor
        (5<=5) xor (x<=5) xor (5<=x) xor (x<=x) xor
        (5>=5) eq (x>=5) not_eq (5>=x);

    5 bitand 5; x bitand 5; 5 bitand x; x bitand x;
    5 bitor 5; x bitor 5; 5 bitor x; x bitor x;
    5 bitxor 5; x bitxor 5; 5 bitxor x; x bitxor x;
    5 bitnot 5; x bitnot 5; 5 bitnot x; x bitnot x;

    not condition;
    ++x; x++;
    -x;
    --x; x--;
}