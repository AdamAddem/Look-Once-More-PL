global mut bool condition = true;

fn if_statements() {
    i32 test = junk;
    if(condition) ;
    if(condition) { condition = false; }
    else if(condition) { condition = true; }
    elif(true) { condition = false; }
    else mut i32 scoped = junk;

    return;
}

fn while_statements() {
    mut bool condition = true;
    while(condition) ;
    while(true) {}
    while(false) {}
    while(condition eq false) {}
    while(condition not_eq true) { mut i32 scoped = junk; }
}