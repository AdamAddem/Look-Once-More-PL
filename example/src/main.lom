__C printf(raw char fmt, __va);

fn foo([20]u32 array) {
    $u32 n = 0;
    while n < 20 {
        __C.printf("%d\n", array[n]);
        ++n;
    }
}

pub fn main() i32 {
    $[20]u32 array = junk;
    $u32 n = 0;
    while n < 20 {
        array[n] = n;
        ++n;
    }
    foo(array);
    return 0;
}