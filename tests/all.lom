global mut i32 mutable_global = junk;
global i32 immutable_global = 5;


fn if_statements() {
    mut bool condition = true;
    if(condition) ;
    if(true) {}
    if(false) {}
    if(condition) { condition = false; }
    else if(condition) { condition = true; }
    elif(true) { condition = false; }
    else mut i32 scoped = junk;
    return;
}

fn while_statements() {
    mut bool condition = true;
    while(condition) ;
    while(true) {}
    while(false) {}
    while(condition eq false) {}
    while(condition not_eq true) { mut i32 scoped = junk; }
}

fn for_statements(bool condition) {
    for( ; ; ) {}

    for(mut i32 i = 0; condition; ++i) {}
    for(mut i32 i = 0; condition; ) {}
    for(mut i32 i = 0; ; ++i) {}
    for(mut i32 i = 0; ; ) {}

    mut i32 i = 0;
    for(; condition; ++i) {}
    for(; condition; ) {}

    for(; ; ++i) {}
}

fn operators() {
    mut i32 x = 0;

    5+5; x+5; 5+x; x+x;
    5-5; x-5; 5-x; x-x;
    5*5; x*5; 5*x; x*x;
    5/5; x/5; 5/x; x/x;
    5^5; x^5; 5^x; x^x;
    5%5; x%5; 5%x; x%x;

    x=5; x=x;
    bool condition =
        (5<5) and (x<5) and (5<x) and (x<x) and
        (5>5) or (x>5) or (5>x) or (x>x) xor
        (5<=5) xor (x<=5) xor (5<=x) xor (x<=x) xor
        (5>=5) eq (x>=5) not_eq (5>=x);

    5 bitand 5; x bitand 5; 5 bitand x; x bitand x;
    5 bitor 5; x bitor 5; 5 bitor x; x bitor x;
    5 bitxor 5; x bitxor 5; 5 bitxor x; x bitxor x;
    5 bitnot 5; x bitnot 5; 5 bitnot x; x bitnot x;

    not condition;
    ++x; x++;
    -x;
    --x; x--;
}

fn empty_function() {}
fn parameter_function(i32 normal, <i32, f32> variant, mut i32 mut_normal, mut <i32, f32> mut_variant) {}
fn return_type_function() -> bool { return true; }

fn return_within_scope() -> bool {
    if(true)
        return true;
    else
        return false;

    return false;
}

fn zeroes() {
    i8 i8zero = 0; u8 u8zero = 0u;
    i16 i16zero = 0; u16 u16zero = 0u;
    i32 i32zero = 0; u32 u32zero = 0u;
    i64 i64zero = 0; u64 u64zero = 0u;

    f32 f32zero = 0f; f64 f64zero = 0.;
}

fn _8bit() {
    i8 imin = -128; i8 imax = 127;
    u8 umax = 255u;
}

fn _16bit() {
    i16 imin = -32768; i16 imax = 32767;
    u16 umax = 65535u;
}

fn _32bit() {
    i32 imin = -2147483648; i32 imax = 2147483647;
    u32 umax = 4294967295u;
}

fn _64bit() {
    i64 imin = -9223372036854775808; i64 imax = 9223372036854775807;
    u64 umax = 18446744073709551615u;
}



fn main() -> i32 {
    zeroes(); _8bit(); _16bit(); _32bit(); _64bit();
    return 0;
